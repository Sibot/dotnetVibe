{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DotnetVibe.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DotnetVibe.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "options": {
                "env": {
                    "DOTNET_WATCH_PROCESS_CLEANUP_TIMEOUT_MS": "15000"
                }
            },
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/DotnetVibe.AppHost/DotnetVibe.AppHost.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
