@page "/counter"
@rendermode InteractiveServer
@inject WeatherApiClient WeatherApi

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<AuthorizeView Policy="@AuthPolicies.WarmUp">
    <Authorized>
        <button class="btn btn-primary" @onclick="IncrementCount" disabled="@isPublishing">Click me</button>
    </Authorized>
    <NotAuthorized>
        <button class="btn btn-primary" disabled title="Sign in with a User or Admin account to request warm-up.">Click me</button>
        <p class="mt-2 text-muted small">Sign in to use the warm-up API.</p>
        <a class="btn btn-sm btn-outline-primary" href="login?returnUrl=/counter">Sign in</a>
    </NotAuthorized>
</AuthorizeView>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <p class="mt-2 text-muted">@statusMessage</p>
}

@code {
    private int currentCount;
    private bool isPublishing;
    private string? statusMessage;

    private async Task IncrementCount()
    {
        currentCount++;
        isPublishing = true;
        statusMessage = null;

        try
        {
            await WeatherApi.RequestWarmUpAsync();
            statusMessage = "Warm-up requested. The Weather page updates automatically via SignalR.";
        }
        catch (HttpRequestException)
        {
            statusMessage = "Failed to request warm-up. Make sure you are signed in with a User or Admin account.";
        }
        catch (Exception)
        {
            statusMessage = "Failed to request warm-up.";
        }
        finally
        {
            isPublishing = false;
        }
    }
}
