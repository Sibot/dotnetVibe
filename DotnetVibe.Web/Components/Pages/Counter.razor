@page "/counter"
@rendermode InteractiveServer
@inject WeatherApiClient WeatherApi

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount" disabled="@isPublishing">Click me</button>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <p class="mt-2 text-muted">@statusMessage</p>
}

@code {
    private int currentCount;
    private bool isPublishing;
    private string? statusMessage;

    private async Task IncrementCount()
    {
        currentCount++;
        isPublishing = true;
        statusMessage = null;

        try
        {
            await WeatherApi.RequestWarmUpAsync();
            statusMessage = "Warm-up requested. The Weather page updates automatically via SignalR.";
        }
        catch (Exception)
        {
            statusMessage = "Failed to request warm-up.";
        }
        finally
        {
            isPublishing = false;
        }
    }
}
